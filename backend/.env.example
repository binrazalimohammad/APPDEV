# Server
PORT=3000

# JWT Secrets (use strong random values in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-key-change-in-production

# Token expiry
ACCESS_TOKEN_EXPIRY=1h
REFRESH_TOKEN_EXPIRY=7d

# Google Sign-In (OAuth2) for mobile clients (ID token verification)
# From Google Cloud Console -> OAuth 2.0 Client IDs (Web/Android/iOS as applicable)
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
